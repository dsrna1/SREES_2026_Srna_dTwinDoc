\begin_layout Standard
Model uključuje dvije varijable stanja:
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $\theta(t)$
\end_inset

 - ugao otklona od ravnotežnog položaja,
\end_layout

\begin_layout Itemize
\begin_inset Formula $\omega$
\end_inset

 - ugaona brzina,
\end_layout

\begin_layout Standard
i sljedeće parametre sistema:
\end_layout

\begin_layout Itemize
\begin_inset Formula $l$
\end_inset

 - dužina klatna,
\end_layout

\begin_layout Itemize
\begin_inset Formula $m$
\end_inset

 - masa klatna,
\end_layout

\begin_layout Itemize
\begin_inset Formula $g$
\end_inset

 - gravitaciono ubrzanje,
\end_layout

\begin_layout Itemize
\begin_inset Formula $k$
\end_inset

 - koeficijent otpora zraka.
\end_layout

\begin_layout Standard
Razmatra se matematičko klatno.
 Tijelo mase m obješeno je na neistegljivoj niti dužine l.
 Ugao otklona od ravnotežnog položaja je 
\begin_inset Formula $\theta$
\end_inset

,
 a ugaona brzina definirana je kao:
\begin_inset Formula 
\[
\omega=\frac{d\theta}{dt}.
\]

\end_inset


\end_layout

\begin_layout Standard
Na tijelo djeluje gravitaciona sila 
\begin_inset Formula $mg$
\end_inset

,
 usmjerena vertikalno prema dolje.
 Tangencijalna komponenta ove sile,
 koja uzrokuje rotaciju oko tačke oslonca,
 iznosi
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
F_{t}=-mg\sin\left(\theta\right).
\]

\end_inset


\end_layout

\begin_layout Standard
Prema drugom Newtonovom zakonu za rotaciono kretanje važi
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\sum\tau=I\alpha,
\]

\end_inset


\end_layout

\begin_layout Standard
gdje je 
\begin_inset Formula $I=ml^{2}$
\end_inset

moment inercije tačkaste mase,
 a 
\begin_inset Formula $\alpha=\frac{d^{2}\theta}{dt^{2}}$
\end_inset

 ugaono ubrzanje.
 
\end_layout

\begin_layout Standard
Moment gravitacione sile jednak je
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\tau_{g}=-mgl\sin\left(\theta\right).
\]

\end_inset


\end_layout

\begin_layout Standard
Pretpostavlja se da sredina stvara silu otpora proporcionalnu ugaonoj brzini.
 Moment sile otpora je
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\tau_{d}=-kl\omega,
\]

\end_inset


\end_layout

\begin_layout Standard
gdje je 
\begin_inset Formula $k$
\end_inset

 koeficijent prigušenja.
\end_layout

\begin_layout Standard
Ukupni moment koji djeluje na klatno iznosi
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\sum\tau=-mgl\sin\left(\theta\right)-kl\omega.
\]

\end_inset


\end_layout

\begin_layout Standard
Primjenom drugog Newtonovog zakona dobija se
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
ml^{2}\frac{d^{2}\theta}{dt^{2}}=-mgl\sin\left(\theta\right)-kl\omega.
\]

\end_inset


\end_layout

\begin_layout Standard
Dijeljenjem cijele jednačine sa 
\begin_inset Formula $ml^{2}$
\end_inset

 dobija se diferencijalna jednačina 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{d^{2}\theta}{dt^{2}}=-\frac{g}{l}\sin\left(\theta\right)-\frac{k}{ml}\omega.
\]

\end_inset


\end_layout

\begin_layout Standard
Vrijedi da je 
\begin_inset Formula $\frac{d^{2}\theta}{dt^{2}}=\frac{d}{dt}\left(\frac{d\theta}{dt}\right)=\frac{d\omega}{dt}=\dot{\omega}$
\end_inset

 pa jednačina postaje
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\dot{\omega}=-\frac{g}{l}\sin\left(\theta\right)-\frac{k}{ml}\omega.
\]

\end_inset


\end_layout

\begin_layout Standard
Algoritam za rješavanje navedene diferencijalne jednačine prikazan je u nastavku.
\end_layout

